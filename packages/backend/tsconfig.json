{
  "extends": [
    "@bpm2025-website/configs/typescript"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "noEmit": false,
    "sourceMap": false,
    "target": "ESNext",
    "lib": ["ESNext"],
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "moduleResolution": "NodeNext",
    "module": "NodeNext"
  },
  "include": [
    "src/**/*.ts"
  ]
}
