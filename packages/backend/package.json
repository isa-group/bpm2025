{
  "name": "@bpm2025-website/backend",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "prisma": "npm run prisma:generate && npm run prisma:migrate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:create-migration": "prisma migrate dev",
    "start": "npm run prisma && npm run app:dev",
    "prod": "npm run prisma && npm run app:prod",
    "app:dev": "DEV=1 node --inspect-wait --disable-warning=ExperimentalWarning --experimental-transform-types src/app.ts",
    "app:prod": "node --disable-warning=ExperimentalWarning --experimental-transform-types src/app.ts",
    "check": "npm run check:types",
    "check:types": "npm run prisma:generate && tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:inspect": "eslint-config-inspector"
  },
  "devDependencies": {
    "@bpm2025-website/configs": "*",
    "@types/nodemailer": "6.4.17",
    "dotenv": "16.4.7"
  },
  "dependencies": {
    "@bpm2025-website/shared": "*",
    "@fastify/cors": "11.0.0",
    "@fastify/formbody": "8.0.2",
    "@prisma/client": "6.3.1",
    "consola": "3.4.0",
    "destr": "2.0.3",
    "fastify": "5.2.1",
    "image-size": "1.2.0",
    "microinvoice": "1.0.6",
    "nodemailer": "6.10.0",
    "prisma": "6.3.1"
  }
}
